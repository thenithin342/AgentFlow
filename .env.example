# Copy this file to .env and fill in your free-tier keys.
# Never commit the real .env file — it is excluded by .gitignore.

# Required — console.groq.com (free, instant signup)
GROQ_API_KEY=

# Required — tavily.com (free tier: 1,000 searches/month)
TAVILY_API_KEY=

# Optional fallback — aistudio.google.com (free, 1M tokens/day)
GOOGLE_API_KEY=

# Checkpointer — defaults to SQLite, zero setup required
CHECKPOINT_DB_PATH=agentflow.db

# Optional — only needed if you switch to PostgresSaver (Phase 4+ upgrade path)
# POSTGRES_CONN_STRING=

# LangSmith Tracing (opt-in — leave false unless actively debugging)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=AgentFlow

# CORS — comma-separated list of allowed origins. Defaults to
# http://localhost:5173 (Vite dev). Set this in production:
#   CORS_ORIGINS=https://app.example.com,https://www.example.com
# CORS_ORIGINS=http://localhost:5173

# Optional API auth — when set, all routes except /health require
# Authorization: Bearer <key> or X-API-Key: <key>. Vite dev/preview
# proxy injects this header server-side (never bundled into client JS).
# Production: add the same header at your reverse proxy (nginx/Caddy).
# AGENTFLOW_API_KEY=

# Test suite uses a separate SQLite file so sync pytest graph and the
# async FastAPI server never contend on the same DB (Windows lock risk).
# CHECKPOINT_DB_PATH=test_agentflow.db
