# =============================================================================
# AgentFlow — environment variable schema
# =============================================================================
#
# Copy this file to `.env` for local dev, OR set the values in the Railway
# dashboard for production deploys. Never commit a real `.env` — it is
# excluded by .gitignore.
#
# Variables are read by `backend/settings.py` (pydantic-settings). Names
# are case-insensitive. Production deploys must set:
#   - ENVIRONMENT=production
#   - JWT_SECRET  (32+ bytes, random)
#   - GROQ_API_KEY
#   - TAVILY_API_KEY
#   - POSTGRES_CONN_STRING  (auto-injected by Railway Postgres plugin)
#
# Generate a JWT secret with:  openssl rand -hex 32

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# "dev" or "production". Flips the pydantic-settings validator into
# strict mode in production (JWT_SECRET becomes required, fail-fast).
ENVIRONMENT=dev
APP_NAME=AgentFlow
APP_VERSION=0.9.0
DEBUG=false
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=1
TIMEOUT_SECONDS=120

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list. Local dev = the Vite ports. Production = the
# frontend's public URL. NEVER use "*" in production — it disables the
# browser's same-origin checks for the entire API.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ---------------------------------------------------------------------------
# Persistence
# ---------------------------------------------------------------------------
# When set, the checkpointer uses PostgresSaver (production).
# When unset, falls back to AsyncSqliteSaver (local dev).
#
# Railway: set this automatically by attaching a Postgres plugin. The
# value looks like:  postgresql://user:pass@host:5432/dbname
# POSTGRES_CONN_STRING=

# Only used when POSTGRES_CONN_STRING is unset (SQLite mode).
CHECKPOINT_DB_PATH=agentflow.db

# Where FAISS indexes, LTM indexes, and uploaded PDFs live on disk.
# On Railway, mount a volume at /app/data to make this durable across
# deploys; the default `/app/data` is ephemeral otherwise.
DATA_DIR=data
FAISS_INDEX_DIR=faiss_indexes
LTM_INDEX_DIR=ltm_indexes

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
# REQUIRED in production. 32+ random bytes. Generate with:
#   openssl rand -hex 32
# If unset in dev, a random ephemeral key is generated at startup
# (all tokens invalidate on restart — fine for local).
JWT_SECRET=

# JWT signing algorithm + access-token TTL. Defaults are sane.
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=1440

# Bootstrap admin. Created on first run if no users exist.
# REQUIRED: set a strong password before first deploy. The app will
# reject production startup if this is empty or set to a known-weak value.
# Rotate by updating this value AND re-hashing with:
#   python -c "from backend.auth import hash_password; print(hash_password('new-pass'))"
# then pasting the hash into data/users.json under the 'admin' key.
# WARNING: changing ADMIN_PASSWORD alone does NOT rotate an existing password —
# it only affects the initial bootstrap on a fresh (empty) user store.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Legacy single-user API key. Used as a dev fallback if JWT is not
# wired. Leave empty in production.
AGENTFLOW_API_KEY=

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
# Per-IP request budget. /chat and /upload share this counter.
RATE_LIMIT_PER_MINUTE=60
# /auth/login gets its own (lower) budget to slow brute force.
RATE_LIMIT_AUTH_PER_MINUTE=10

# ---------------------------------------------------------------------------
# LangSmith / observability (optional)
# ---------------------------------------------------------------------------
# Set LANGSMITH_TRACING=true after creating a LangSmith project to
# capture full LLM + graph traces. The env-var name LangChain reads
# is LANGSMITH_API_KEY (not LANGCHAIN_API_KEY) — we accept both for
# compat.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=AgentFlow
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=AgentFlow

# ---------------------------------------------------------------------------
# LLM providers
# ---------------------------------------------------------------------------
# Required. Free at console.groq.com.
GROQ_API_KEY=

# Optional fallback keys. Rotated round-robin if multiple are set.
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# Optional. Free at aistudio.google.com (1M tokens/day).
GOOGLE_API_KEY=

# Required. Free at tavily.com (1000 searches/month).
TAVILY_API_KEY=

# Set true to fail fast at startup if GROQ_API_KEY is missing.
# Default false so the app can boot in offline / demo mode.
AGENTFLOW_REQUIRE_GROQ=false

# ---------------------------------------------------------------------------
# Test-only overrides (set by tests, never in production)
# ---------------------------------------------------------------------------
# CHECKPOINT_DB_PATH=test_agentflow.db
# DATA_DIR=tests/_tmp_data
